# ==========================================================================
# Environment variables for OAC → Fabric migration
# ==========================================================================
# Copy this file to .env and fill in the values for your environment.
# These override config/migration.toml settings via pydantic-settings.

# --- Oracle Analytics Cloud ---
OAC_BASE_URL=https://oac-instance.analytics.ocp.oraclecloud.com
OAC_CLIENT_ID=
OAC_CLIENT_SECRET=
OAC_TOKEN_URL=https://idcs-xxxxx.identity.oraclecloud.com/oauth2/v1/token
OAC_API_VERSION=20210901

# --- RPD file ---
RPD_XML_PATH=./data/rpd_export.xml

# --- Microsoft Fabric ---
FABRIC_WORKSPACE_ID=
FABRIC_LAKEHOUSE_ID=
FABRIC_SQL_ENDPOINT=

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4

# --- Azure Application Insights (Phase 14) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Operational ---
LOG_LEVEL=INFO
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0
PAGE_SIZE=100

# --- Notification Channels (optional) ---
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
EMAIL_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=...
EMAIL_SENDER=migration-alerts@your-domain.com
EMAIL_RECIPIENTS=team-lead@company.com,data-eng@company.com
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# --- Azure Authentication (optional — managed identity preferred) ---
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=your-service-principal-secret

# --- Azure Key Vault (optional — for secret management) ---
# AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/
