        dataType: string
        lineageTag: e9f11d22-8d72-4f8b-97c3-84184613b644
        sourceColumn: FreightCost
        summarizeBy: none

    column 'Revenue' = [Quantity] * [UnitPrice] * (1 - [DiscountPct])
        dataType: string
        lineageTag: e25e46b1-12b2-41d2-b985-e0d6dfd650b4

    column 'TotalCost' = [Quantity] * [UnitCost] + [TaxAmount] + [FreightCost]
        dataType: string
        lineageTag: d7098c4d-1f6d-4036-abb4-6790def25cb5

    column 'Profit' = [Revenue] - [TotalCost]
        dataType: string
        lineageTag: ef420ef6-4ea2-4dbd-826b-2f94ee20973d

    column 'ProfitMargin' = IF [Revenue] > 0 THEN [Profit] / [Revenue] * 100 ELSE 0 END
        dataType: string
        lineageTag: 03e2a95d-5078-48c6-8987-72da6ea84237

    column 'DiscountAmount' = [Quantity] * [UnitPrice] * [DiscountPct]
        dataType: string
        lineageTag: a0bfd45f-65a0-45fc-8203-f0a16cc29b6d

    column 'PriceCategory' = IF [UnitPrice] > 500 THEN 'Premium' ELSEIF [UnitPrice] > 100 THEN 'Mid-Range' ELSE 'Budget' END
        dataType: string
        lineageTag: 6eef2434-e284-4f07-bfea-919dc7eb28c2

    column 'IsHighValue' = IF [Revenue] > 5000 THEN 'Yes' ELSE 'No' END
        dataType: string
        lineageTag: 78d4f546-81b8-411c-adee-f21df06f17d4

    measure 'AvgOrderValue' = SUM('Sales Data Warehouse'[[Revenue]]) / COUNTD([OrderID])
        lineageTag: 5a4bcf5a-a1cd-4e38-b06f-ea3b69958c50
        formatString: #,0.00
        displayFolder: Measures

