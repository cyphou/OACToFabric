        dataType: string
        lineageTag: 7da72267-f4b1-47f4-9b73-dd4fe4978d95
        sourceColumn: FreightCost
        summarizeBy: none

    column 'Revenue' = [Quantity] * [UnitPrice] * (1 - [DiscountPct])
        dataType: string
        lineageTag: 9677c97e-6be1-4d90-b833-c876576a6012

    column 'TotalCost' = [Quantity] * [UnitCost] + [TaxAmount] + [FreightCost]
        dataType: string
        lineageTag: 1576c941-0b45-40ba-956b-c9a50f12ec3c

    column 'Profit' = [Revenue] - [TotalCost]
        dataType: string
        lineageTag: 7e10ff41-5e3a-4ee1-aa36-28ca9d08b1fa

    column 'ProfitMargin' = IF [Revenue] > 0 THEN [Profit] / [Revenue] * 100 ELSE 0 END
        dataType: string
        lineageTag: 404bcc4c-ff17-493a-8bf1-b4f1d909a297

    column 'DiscountAmount' = [Quantity] * [UnitPrice] * [DiscountPct]
        dataType: string
        lineageTag: ec60945a-d55b-4167-9314-f80d00aa6e4f

    column 'PriceCategory' = IF [UnitPrice] > 500 THEN 'Premium' ELSEIF [UnitPrice] > 100 THEN 'Mid-Range' ELSE 'Budget' END
        dataType: string
        lineageTag: f2536a54-69cf-4cb4-80b3-15766e9b389d

    column 'IsHighValue' = IF [Revenue] > 5000 THEN 'Yes' ELSE 'No' END
        dataType: string
        lineageTag: 35a7560e-e978-4152-99c8-eb8cb3e3a657

    measure 'AvgOrderValue' = SUM('Sales Data Warehouse'[[Revenue]]) / COUNTD([OrderID])
        lineageTag: 448b4d48-dd23-4e8d-8b68-46e781d3432a
        formatString: #,0.00
        displayFolder: Measures

