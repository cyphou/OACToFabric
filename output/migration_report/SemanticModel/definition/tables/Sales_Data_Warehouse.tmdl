        dataType: string
        lineageTag: 88ce5b47-9f76-41fe-b90c-881334dd83ff
        sourceColumn: FreightCost
        summarizeBy: none

    column 'Revenue' = [Quantity] * [UnitPrice] * (1 - [DiscountPct])
        dataType: string
        lineageTag: fbcf8802-02cc-40a8-88c0-936be51facf1

    column 'TotalCost' = [Quantity] * [UnitCost] + [TaxAmount] + [FreightCost]
        dataType: string
        lineageTag: 3e3c27ec-36d4-4c98-a4c0-5a00412af4b9

    column 'Profit' = [Revenue] - [TotalCost]
        dataType: string
        lineageTag: 924c1fad-4b1f-459d-915d-c6aa50695d3f

    column 'ProfitMargin' = IF [Revenue] > 0 THEN [Profit] / [Revenue] * 100 ELSE 0 END
        dataType: string
        lineageTag: c994ed8a-7a36-40e3-97fa-31adc410f1d1

    column 'DiscountAmount' = [Quantity] * [UnitPrice] * [DiscountPct]
        dataType: string
        lineageTag: 1a7fb6fb-9d05-4dca-8b4f-e45aefc5d28d

    column 'PriceCategory' = IF [UnitPrice] > 500 THEN 'Premium' ELSEIF [UnitPrice] > 100 THEN 'Mid-Range' ELSE 'Budget' END
        dataType: string
        lineageTag: c92bde99-db9d-4055-abaa-c723a552a644

    column 'IsHighValue' = IF [Revenue] > 5000 THEN 'Yes' ELSE 'No' END
        dataType: string
        lineageTag: ed84008f-1204-4790-8d42-0d6acb83479c

    measure 'AvgOrderValue' = SUM('Sales Data Warehouse'[[Revenue]]) / COUNTD([OrderID])
        lineageTag: a4694073-07eb-4998-9850-4269c4a38138
        formatString: #,0.00
        displayFolder: Measures

