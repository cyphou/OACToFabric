        lineageTag: 6b961691-4d49-4742-91a9-9f0ce37326f4
        sourceColumn: FreightCost
        summarizeBy: none

    column 'Revenue' = [Quantity] * [UnitPrice] * (1 - [DiscountPct])
        dataType: string
        lineageTag: 532d0e38-dccc-49e7-8512-9925ec5d6f1a

    column 'TotalCost' = [Quantity] * [UnitCost] + [TaxAmount] + [FreightCost]
        dataType: string
        lineageTag: 9ac84f53-3269-4d60-ba26-0b38e10a817d

    column 'Profit' = [Revenue] - [TotalCost]
        dataType: string
        lineageTag: e51218c6-2a20-4fb0-adaf-c3d3daa79624

    column 'ProfitMargin' = IF [Revenue] > 0 THEN [Profit] / [Revenue] * 100 ELSE 0 END
        dataType: string
        lineageTag: e1959f7c-9001-4a5b-bc28-5da1169e0128

    column 'DiscountAmount' = [Quantity] * [UnitPrice] * [DiscountPct]
        dataType: string
        lineageTag: abcb8de4-9c1b-4779-b42a-e58d0ed6833a

    column 'PriceCategory' = IF [UnitPrice] > 500 THEN 'Premium' ELSEIF [UnitPrice] > 100 THEN 'Mid-Range' ELSE 'Budget' END
        dataType: string
        lineageTag: 7b4b4d24-656a-42bc-8fd1-bfca69d21322

    column 'IsHighValue' = IF [Revenue] > 5000 THEN 'Yes' ELSE 'No' END
        dataType: string
        lineageTag: 51cf43d9-5d98-46e5-aa6b-7f2505290a2d

    measure 'AvgOrderValue' = SUM('Sales Data Warehouse'[[Revenue]]) / COUNTD([OrderID])
        lineageTag: 52dd11da-2f64-4686-be19-cb10da044d7c
        formatString: #,0.00
        displayFolder: Measures

