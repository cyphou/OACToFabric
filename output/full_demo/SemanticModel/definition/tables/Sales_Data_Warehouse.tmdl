        dataType: string
        lineageTag: 24423404-328c-477c-b551-11e9c6d90293
        sourceColumn: FreightCost
        summarizeBy: none

    column 'Revenue' = [Quantity] * [UnitPrice] * (1 - [DiscountPct])
        dataType: string
        lineageTag: e838c561-a710-427b-9d2d-836bcab50e33

    column 'TotalCost' = [Quantity] * [UnitCost] + [TaxAmount] + [FreightCost]
        dataType: string
        lineageTag: 4c48e02e-ff36-470a-b55f-27308b58b295

    column 'Profit' = [Revenue] - [TotalCost]
        dataType: string
        lineageTag: 03063961-420d-4e61-8f95-4dc8d694deb7

    column 'ProfitMargin' = IF [Revenue] > 0 THEN [Profit] / [Revenue] * 100 ELSE 0 END
        dataType: string
        lineageTag: 384f1201-f8ae-4674-aef8-deae009f3a4c

    column 'DiscountAmount' = [Quantity] * [UnitPrice] * [DiscountPct]
        dataType: string
        lineageTag: 33a86033-4358-4205-91f4-c8ebdd9f6afd

    column 'PriceCategory' = IF [UnitPrice] > 500 THEN 'Premium' ELSEIF [UnitPrice] > 100 THEN 'Mid-Range' ELSE 'Budget' END
        dataType: string
        lineageTag: d3a93326-1d15-4fa3-896a-eb74b1be343b

    column 'IsHighValue' = IF [Revenue] > 5000 THEN 'Yes' ELSE 'No' END
        dataType: string
        lineageTag: 6a03948d-6ab4-446d-9f3d-1ba96193bbd1

    measure 'AvgOrderValue' = SUM('Sales Data Warehouse'[[Revenue]]) / COUNTD([OrderID])
        lineageTag: 87d5f0a0-d278-49c5-8449-ba7f7d8c48d5
        formatString: #,0.00
        displayFolder: Measures

