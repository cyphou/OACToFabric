<?xml version="1.0" encoding="UTF-8"?>
<!--
  OAC RPD XML — Complex Enterprise Model
  Complexity: Complex
  Tables: 8 physical, 6 logical, 3 subject areas
  Features: Multiple hierarchies, 2 security roles, init blocks, data flows,
            connections, complex expressions, all RPD layers
-->
<Repository>
  <!-- ═══════════════════ Physical Layer ═══════════════════ -->

  <PhysicalTable name="DIM_DATE" mdsid="phys_date_001">
    <Name>DIM_DATE</Name>
    <PhysicalColumn name="DATE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="FULL_DATE" dataType="DATE"><DataType>DATE</DataType></PhysicalColumn>
    <PhysicalColumn name="YEAR" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="QUARTER" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="MONTH_NUM" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="MONTH_NAME" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="WEEK_NUM" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="DIM_PRODUCT" mdsid="phys_prod_001">
    <Name>DIM_PRODUCT</Name>
    <PhysicalColumn name="PRODUCT_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="PRODUCT_NAME" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="CATEGORY" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="SUBCATEGORY" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="BRAND" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="UNIT_COST" dataType="NUMERIC"><DataType>NUMERIC</DataType></PhysicalColumn>
    <PhysicalColumn name="UNIT_PRICE" dataType="NUMERIC"><DataType>NUMERIC</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="DIM_CUSTOMER" mdsid="phys_cust_001">
    <Name>DIM_CUSTOMER</Name>
    <PhysicalColumn name="CUSTOMER_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="CUSTOMER_NAME" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="SEGMENT" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="REGION" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="COUNTRY" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="STATE" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="CITY" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="DIM_STORE" mdsid="phys_store_001">
    <Name>DIM_STORE</Name>
    <PhysicalColumn name="STORE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="STORE_NAME" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="STORE_TYPE" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="REGION" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="DIM_CHANNEL" mdsid="phys_chan_001">
    <Name>DIM_CHANNEL</Name>
    <PhysicalColumn name="CHANNEL_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="CHANNEL_NAME" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
    <PhysicalColumn name="CHANNEL_CLASS" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="FACT_SALES" mdsid="phys_sales_001">
    <Name>FACT_SALES</Name>
    <PhysicalColumn name="SALES_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="DATE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="PRODUCT_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="CUSTOMER_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="STORE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="CHANNEL_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="QUANTITY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="UNIT_PRICE" dataType="NUMERIC"><DataType>NUMERIC</DataType></PhysicalColumn>
    <PhysicalColumn name="DISCOUNT_PCT" dataType="NUMERIC"><DataType>NUMERIC</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="FACT_RETURNS" mdsid="phys_ret_001">
    <Name>FACT_RETURNS</Name>
    <PhysicalColumn name="RETURN_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="SALES_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="RETURN_DATE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="RETURN_QUANTITY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="REASON_CODE" dataType="VARCHAR"><DataType>VARCHAR</DataType></PhysicalColumn>
  </PhysicalTable>

  <PhysicalTable name="FACT_BUDGET" mdsid="phys_bud_001">
    <Name>FACT_BUDGET</Name>
    <PhysicalColumn name="BUDGET_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="DATE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="PRODUCT_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="STORE_KEY" dataType="INTEGER"><DataType>INTEGER</DataType></PhysicalColumn>
    <PhysicalColumn name="BUDGET_AMOUNT" dataType="NUMERIC"><DataType>NUMERIC</DataType></PhysicalColumn>
  </PhysicalTable>

  <!-- ═══════════════════ Logical Layer ═══════════════════ -->

  <LogicalTable name="Time">
    <Name>Time</Name>
    <LogicalColumn name="Date"><Name>Date</Name>
      <DerivedExpression>"DIM_DATE"."FULL_DATE"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Year"><Name>Year</Name>
      <DerivedExpression>"DIM_DATE"."YEAR"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Quarter"><Name>Quarter</Name>
      <DerivedExpression>"DIM_DATE"."QUARTER"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Month"><Name>Month</Name>
      <DerivedExpression>"DIM_DATE"."MONTH_NAME"</DerivedExpression>
    </LogicalColumn>
    <LogicalHierarchy name="TimeHierarchy">
      <Level name="Year"/>
      <Level name="Quarter"/>
      <Level name="Month"/>
      <Level name="Date"/>
    </LogicalHierarchy>
    <LogicalTableSource physicalTable="DIM_DATE"/>
  </LogicalTable>

  <LogicalTable name="Product">
    <Name>Product</Name>
    <LogicalColumn name="Product Name"><Name>Product Name</Name>
      <DerivedExpression>"DIM_PRODUCT"."PRODUCT_NAME"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Category"><Name>Category</Name>
      <DerivedExpression>"DIM_PRODUCT"."CATEGORY"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Subcategory"><Name>Subcategory</Name>
      <DerivedExpression>"DIM_PRODUCT"."SUBCATEGORY"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Brand"><Name>Brand</Name>
      <DerivedExpression>"DIM_PRODUCT"."BRAND"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Margin Pct" expression="true">
      <Name>Margin Pct</Name>
      <Expression>("DIM_PRODUCT"."UNIT_PRICE" - "DIM_PRODUCT"."UNIT_COST") / "DIM_PRODUCT"."UNIT_PRICE" * 100</Expression>
    </LogicalColumn>
    <LogicalHierarchy name="ProductHierarchy">
      <Level name="Category"/>
      <Level name="Subcategory"/>
      <Level name="Brand"/>
      <Level name="Product Name"/>
    </LogicalHierarchy>
    <LogicalTableSource physicalTable="DIM_PRODUCT"/>
  </LogicalTable>

  <LogicalTable name="Customer">
    <Name>Customer</Name>
    <LogicalColumn name="Customer Name"><Name>Customer Name</Name>
      <DerivedExpression>"DIM_CUSTOMER"."CUSTOMER_NAME"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Segment"><Name>Segment</Name>
      <DerivedExpression>"DIM_CUSTOMER"."SEGMENT"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Region"><Name>Region</Name>
      <DerivedExpression>"DIM_CUSTOMER"."REGION"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Country"><Name>Country</Name>
      <DerivedExpression>"DIM_CUSTOMER"."COUNTRY"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="City"><Name>City</Name>
      <DerivedExpression>"DIM_CUSTOMER"."CITY"</DerivedExpression>
    </LogicalColumn>
    <LogicalHierarchy name="GeoHierarchy">
      <Level name="Region"/>
      <Level name="Country"/>
      <Level name="State"/>
      <Level name="City"/>
    </LogicalHierarchy>
    <LogicalTableSource physicalTable="DIM_CUSTOMER"/>
  </LogicalTable>

  <LogicalTable name="Sales">
    <Name>Sales</Name>
    <LogicalColumn name="Quantity"><Name>Quantity</Name>
      <DerivedExpression>"FACT_SALES"."QUANTITY"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Revenue" expression="true">
      <Name>Revenue</Name>
      <Expression>SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE" * (1 - "FACT_SALES"."DISCOUNT_PCT"))</Expression>
    </LogicalColumn>
    <LogicalColumn name="Cost" expression="true">
      <Name>Cost</Name>
      <Expression>SUM("FACT_SALES"."QUANTITY" * "DIM_PRODUCT"."UNIT_COST")</Expression>
    </LogicalColumn>
    <LogicalColumn name="Profit" expression="true">
      <Name>Profit</Name>
      <Expression>SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE" * (1 - "FACT_SALES"."DISCOUNT_PCT")) - SUM("FACT_SALES"."QUANTITY" * "DIM_PRODUCT"."UNIT_COST")</Expression>
    </LogicalColumn>
    <LogicalColumn name="Profit Margin" expression="true">
      <Name>Profit Margin</Name>
      <Expression>CASE WHEN SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE") = 0 THEN 0 ELSE (SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE" * (1 - "FACT_SALES"."DISCOUNT_PCT")) - SUM("FACT_SALES"."QUANTITY" * "DIM_PRODUCT"."UNIT_COST")) / SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE") * 100 END</Expression>
    </LogicalColumn>
    <LogicalColumn name="Return Rate" expression="true">
      <Name>Return Rate</Name>
      <Expression>CASE WHEN SUM("FACT_SALES"."QUANTITY") = 0 THEN 0 ELSE SUM("FACT_RETURNS"."RETURN_QUANTITY") / SUM("FACT_SALES"."QUANTITY") * 100 END</Expression>
    </LogicalColumn>
    <LogicalColumn name="Budget Variance" expression="true">
      <Name>Budget Variance</Name>
      <Expression>SUM("FACT_SALES"."QUANTITY" * "FACT_SALES"."UNIT_PRICE") - SUM("FACT_BUDGET"."BUDGET_AMOUNT")</Expression>
    </LogicalColumn>
    <LogicalTableSource physicalTable="FACT_SALES"/>
  </LogicalTable>

  <LogicalTable name="Returns">
    <Name>Returns</Name>
    <LogicalColumn name="Return Quantity"><Name>Return Quantity</Name>
      <DerivedExpression>"FACT_RETURNS"."RETURN_QUANTITY"</DerivedExpression>
    </LogicalColumn>
    <LogicalColumn name="Reason Code"><Name>Reason Code</Name>
      <DerivedExpression>"FACT_RETURNS"."REASON_CODE"</DerivedExpression>
    </LogicalColumn>
    <LogicalTableSource physicalTable="FACT_RETURNS"/>
  </LogicalTable>

  <LogicalTable name="Budget">
    <Name>Budget</Name>
    <LogicalColumn name="Budget Amount"><Name>Budget Amount</Name>
      <DerivedExpression>"FACT_BUDGET"."BUDGET_AMOUNT"</DerivedExpression>
    </LogicalColumn>
    <LogicalTableSource physicalTable="FACT_BUDGET"/>
  </LogicalTable>

  <!-- ═══════════════════ Presentation Layer ═══════════════════ -->

  <SubjectArea name="Executive Sales">
    <Name>Executive Sales</Name>
    <PresentationTable name="Time">
      <PresentationColumn name="Date" logicalTable="Time"/>
      <PresentationColumn name="Year" logicalTable="Time"/>
      <PresentationColumn name="Quarter" logicalTable="Time"/>
      <PresentationColumn name="Month" logicalTable="Time"/>
    </PresentationTable>
    <PresentationTable name="Product">
      <PresentationColumn name="Product Name" logicalTable="Product"/>
      <PresentationColumn name="Category" logicalTable="Product"/>
      <PresentationColumn name="Brand" logicalTable="Product"/>
    </PresentationTable>
    <PresentationTable name="Customer">
      <PresentationColumn name="Customer Name" logicalTable="Customer"/>
      <PresentationColumn name="Region" logicalTable="Customer"/>
      <PresentationColumn name="Country" logicalTable="Customer"/>
    </PresentationTable>
    <PresentationTable name="Measures">
      <PresentationColumn name="Revenue" logicalTable="Sales"/>
      <PresentationColumn name="Profit" logicalTable="Sales"/>
      <PresentationColumn name="Profit Margin" logicalTable="Sales"/>
      <PresentationColumn name="Budget Variance" logicalTable="Sales"/>
    </PresentationTable>
  </SubjectArea>

  <SubjectArea name="Product Performance">
    <Name>Product Performance</Name>
    <PresentationTable name="Product">
      <PresentationColumn name="Product Name" logicalTable="Product"/>
      <PresentationColumn name="Category" logicalTable="Product"/>
      <PresentationColumn name="Subcategory" logicalTable="Product"/>
      <PresentationColumn name="Margin Pct" logicalTable="Product"/>
    </PresentationTable>
    <PresentationTable name="Sales">
      <PresentationColumn name="Revenue" logicalTable="Sales"/>
      <PresentationColumn name="Quantity" logicalTable="Sales"/>
      <PresentationColumn name="Return Rate" logicalTable="Sales"/>
    </PresentationTable>
  </SubjectArea>

  <SubjectArea name="Returns Analysis">
    <Name>Returns Analysis</Name>
    <PresentationTable name="Time">
      <PresentationColumn name="Year" logicalTable="Time"/>
      <PresentationColumn name="Month" logicalTable="Time"/>
    </PresentationTable>
    <PresentationTable name="Product">
      <PresentationColumn name="Product Name" logicalTable="Product"/>
      <PresentationColumn name="Category" logicalTable="Product"/>
    </PresentationTable>
    <PresentationTable name="Returns">
      <PresentationColumn name="Return Quantity" logicalTable="Returns"/>
      <PresentationColumn name="Reason Code" logicalTable="Returns"/>
    </PresentationTable>
  </SubjectArea>

  <!-- ═══════════════════ Security ═══════════════════ -->

  <SecurityRole name="Regional_Manager">
    <Name>Regional_Manager</Name>
    <Member name="alice"/>
    <Member name="bob"/>
    <Permission object="Sales" access="read"/>
    <Permission object="Budget" access="read"/>
    <Permission object="Customer" access="read"/>
  </SecurityRole>

  <SecurityRole name="Analyst">
    <Name>Analyst</Name>
    <Member name="charlie"/>
    <Member name="diana"/>
    <Permission object="Sales" access="read"/>
    <Permission object="Returns" access="read"/>
  </SecurityRole>

  <InitBlock name="RLS_Region">
    <SQL>SELECT REGION FROM USER_REGION_ACCESS WHERE USERNAME = VALUEOF(NQ_SESSION.USER)</SQL>
    <Variable name="NQ_SESSION.UserRegion"/>
  </InitBlock>

  <InitBlock name="RLS_Segment">
    <SQL>SELECT SEGMENT FROM USER_SEGMENT_ACCESS WHERE USERNAME = VALUEOF(NQ_SESSION.USER)</SQL>
    <Variable name="NQ_SESSION.UserSegment"/>
  </InitBlock>

  <!-- ═══════════════════ Connections ═══════════════════ -->

  <Connection name="DW_Oracle_Primary">
    <Name>DW_Oracle_Primary</Name>
  </Connection>

  <Connection name="DW_Oracle_Replica">
    <Name>DW_Oracle_Replica</Name>
  </Connection>

  <!-- ═══════════════════ Data Flows ═══════════════════ -->

  <DataFlow name="Daily_Sales_ETL">
    <Name>Daily_Sales_ETL</Name>
  </DataFlow>

  <DataFlow name="Monthly_Budget_Load">
    <Name>Monthly_Budget_Load</Name>
  </DataFlow>
</Repository>
